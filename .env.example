# ============================================
# 麻将游戏抽卡器 · 环境变量
# ============================================

# ---------- 数据库（生产用）----------
# 没设置时自动用 Mock 模式（数据存内存，重启即丢）
DATABASE_URL="postgresql://user:password@host:5432/db"

# ---------- 应用配置 ----------
# 用于拼邀请二维码的链接域名（生产环境填你的域名，比如 https://majiang.xxx.com）
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="麻将抽卡器"

# ---------- 后台管理密码 ----------
# 访问 /admin/cards 时需要输入的密码（也用于写入卡牌时的 API 鉴权）
# 必须设置一个强一点的密码，不设 = 整个后台被锁死
ADMIN_PASSWORD="改成你的密码"

# ---------- Cookie 安全 ----------
# 部署在 HTTPS 域名下时设为 1，让 cookie 带 Secure 标志（防止被中间人窃取）
# 本地开发不要设
COOKIE_SECURE="0"

# ---------- 实时同步（可选）----------
# 没设置时用 SSE 模式（不依赖外部服务）
# 设置了就用 Pusher/Ably
NEXT_PUBLIC_PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""