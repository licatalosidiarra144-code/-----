# ============================================
# 麻将游戏抽卡器 · 环境变量
# ============================================

# ---------- 数据库（生产用）----------
# 没设置时自动用 Mock 模式（数据存内存）
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# ---------- 应用配置 ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="麻将抽卡器"

# ---------- 实时同步（可选）----------
# 没设置时用 SSE 模式（不依赖外部服务）
# 设置了就用 Pusher/Ably
NEXT_PUBLIC_PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""
